APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Base de datos principal de Laravel (usuarios, sesiones, migraciones locales)
# ---------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# En este proyecto suele usarse PostgreSQL local (copie y adapte a su .env real):
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=inventario_de_lenguas
# DB_USERNAME=postgres
# DB_PASSWORD=su_clave

# ---------------------------------------------------------------------------
# PostgreSQL externo SIRT (conexión "colbeef" en config/database.php)
# Usado por: Despacho de Lenguas (búsqueda vehículo) y Decomisos (inspecciones).
# Si POSTGRES_HOST está vacío, esas funciones no consultan SIRT.
# ---------------------------------------------------------------------------
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=sirt
POSTGRES_USER=
POSTGRES_PASSWORD=
# Esquemas adicionales (sai, trazabilidad_proceso, etc.); en muchos casos "public" basta
POSTGRES_SEARCH_PATH=public
# Opcional: require, prefer, disable, etc.
# POSTGRES_SSLMODE=prefer

# Forzar que Laravel trate SIRT como disponible aunque falte alguna variable:
# POSTGRES_ENABLED=true
# COLBEEF_DB_ENABLED=true

# Credenciales alternativas (si no usa el prefijo POSTGRES_*):
# COLBEEF_DB_HOST=
# COLBEEF_DB_PORT=5432
# COLBEEF_DB_DATABASE=
# COLBEEF_DB_USERNAME=
# COLBEEF_DB_PASSWORD=
# COLBEEF_DB_URL=
# Nombre de la conexión en database.php (por defecto "colbeef"):
# COLBEEF_DB_CONNECTION=colbeef

# ---------------------------------------------------------------------------
# Despacho de Lenguas — filtro user_name en trazabilidad_proceso.vehiculo_asignado
# ---------------------------------------------------------------------------
# Valor de la columna user_name que usa su SQL en pgAdmin (ej. porteria52):
# DESPACHO_VEHICULO_USER_NAME=porteria52
# Si es true, se usa el username del usuario logueado en Laravel en lugar del anterior:
# DESPACHO_USE_AUTH_USERNAME=false
# Lectores de código: último segmento numérico tras "-" (longitud) que se quita para coincidir con id_producto local (p. ej. 2604-02375-6000 → 2604-02375).
# DESPACHO_CODIGO_BARRAS_SUFIJO_DIGITOS=4

# ---------------------------------------------------------------------------
# Decomisos de Lenguas — consulta sai.inspeccion en SIRT
# ---------------------------------------------------------------------------
# Conexión Laravel a usar (debe existir en config/database.php, por defecto "colbeef"):
# DECOMISOS_SIRT_CONNECTION=colbeef
# Mismos filtros que en su consulta: id_parte_producto e id_dictamen
# DECOMISOS_ID_PARTE_PRODUCTO=24
# DECOMISOS_ID_DICTAMEN=3

# ---------------------------------------------------------------------------
# Ingresos de Lenguas — filtros y consulta SIRT (trazabilidad_proceso)
# ---------------------------------------------------------------------------
# Zona para "Volver a hoy" y fechas por defecto (evita adelantar el día si APP_TIMEZONE=UTC):
# INGRESOS_LENGUAS_FECHA_OPERACION_TIMEZONE=America/Bogota
# (También se usa para mostrar en pantalla columnas como «Importado» cuando APP_TIMEZONE=UTC.)
# INGRESOS_LENGUAS_CONNECTION=colbeef

# Inventario de Lenguas: segundos entre cada importación automática del día (SIRT) con la página abierta (mínimo 30). 0 = solo al cargar.
# INVENTARIO_LENGUAS_SYNC_INTERVAL=120

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
